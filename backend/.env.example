# This is an example .env file for the Thrifter backend application. It contains environment variables for the database connection, JWT configuration, Cloudinary API credentials, and application settings. The DATABASE_URL variable is used to connect to a PostgreSQL database, while the JWT_SECRET and JWT_EXP_SECONDS variables are used for authentication and token expiration. The CLOUDINARY_* variables are used for managing image uploads and storage with Cloudinary. The DEBUG and SEED_DEMO variables are used to control the application's debug mode and whether to seed the database with demo data during development or testing. This file should be copied to .env and filled with actual values before running the application.
# Database
DATABASE_URL=postgresql://postgres:postgres@localhost/thrifter

# JWT
JWT_SECRET=generate-a-long-random-string-here
JWT_EXP_SECONDS=3600

# Cloudinary (fallback image store for ISPs that block the R2 domain)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cloudflare R2 (current image storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=thrifter-images
R2_PUBLIC_BASE_URL=https://images.thrifter-ug.com

# PostHog server-side events (public project key, same one the frontend uses)
POSTHOG_PROJECT_API_KEY=phc_your_project_key
POSTHOG_CAPTURE_HOST=https://eu.i.posthog.com

# App
DEBUG=False
SEED_DEMO=False
